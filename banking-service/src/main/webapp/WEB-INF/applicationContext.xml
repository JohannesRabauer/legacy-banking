<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
             xmlns:context="http://www.springframework.org/schema/context"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans
                 http://www.springframework.org/schema/beans/spring-beans-3.2.xsd
                 http://www.springframework.org/schema/context
                 http://www.springframework.org/schema/context/spring-context-3.2.xsd">

        <context:annotation-config />

    <bean id="databaseManager" class="com.legacybank.service.DatabaseManager">
        <property name="jdbcUrl" value="#{'jdbc:postgresql://' + (systemEnvironment['DB_HOST'] != null ? systemEnvironment['DB_HOST'] : 'localhost') + ':5432/bankdb'}" />
        <property name="username" value="#{systemEnvironment['DB_USER'] != null ? systemEnvironment['DB_USER'] : 'bankuser'}" />
        <property name="password" value="#{systemEnvironment['DB_PASSWORD'] != null ? systemEnvironment['DB_PASSWORD'] : 'bankpassword'}" />
    </bean>

</beans>
